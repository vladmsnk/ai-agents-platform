  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@gateway.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["a2a-caller", "a2a-admin"]
    },
    {
      "username": "service-account-gateway",
      "enabled": true,
      "serviceAccountClientId": "gateway",
      "clientRoles": {
        "realm-management": ["manage-clients", "view-clients", "manage-users", "view-users"]
      },
      "realmRoles": ["a2a-caller", "a2a-admin"]
    }
  ]
