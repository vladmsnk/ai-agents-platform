{
  "realm": "agents",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "a2a-caller",
        "description": "Can send messages to A2A agents via the gateway"
      },
      {
        "name": "a2a-admin",
        "description": "Can register, update, and delete agents"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend-admin",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8080/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:8080", "http://localhost:5173"],
      "protocol": "openid-connect",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "gateway",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "gateway-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "agent-translator",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
