      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "agent-sentiment-analyzer",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "sentiment-analyzer-secret",
      "serviceAccountsEnabled": true,
